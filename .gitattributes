# Normalize line endings: let git handle text, but keep shell scripts LF so bash runs them.
* text=auto
*.sh   text eol=lf
*.py   text eol=lf
*.bat  text eol=crlf
*.ps1  text eol=crlf

# Treat known binaries as binary (Phase 3 artifacts, if ever added explicitly).
*.bit  binary
*.dcp  binary
*.npy  binary
*.wav  binary
*.ckpt binary
*.pth  binary
