# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/

# ── Virtual environment (this project owns its own) ──────────────────────
.venv/
venv/
env/

# ── Experiment artifacts (regenerable; pointers tracked, blobs ignored) ──
*.ckpt
*.pth
*.pt
*.onnx
experiments/**/checkpoints/
experiments/**/*.ckpt
# throwaway smoke runs (real runs are tracked); .gitignore has no inline comments
experiments/*quick*/
lightning_logs/
wandb/
runs/
tensorboard/
*.log
# redirected stderr + run logs of background runs (e.g. experiments/*/run.log.err)
*.log.err
experiments/**/run.log*
# full-split evaluation outputs (large per-scene dumps; regenerate with tools/eval_full_dev.py)
experiments/**/full_*_eval.json
# deployment-accurate eval outputs + exported deploy weights (regenerate: export_weights.py + eval_deploy.py)
experiments/**/deploy_*_eval*.json
*.npz
# generated HLS weight ROM (4 MB; regenerate: gen_hls_weights.py) + golden C-sim vectors (dump_hls_vectors.py)
hls/src/c7_weights.hpp
hls/tb/vectors_*.txt

# ── Datasets / large binaries (live outside the repo: D:\DataSet\LRS3) ───
data_cache/
.dataset_cache/
*.wav
*.npy
*.bin
!analysis/**/*.bin   # keep any tiny fixtures explicitly added under analysis/

# ── Hardware toolchain artifacts (Phase 3; regenerable) ──────────────────
*.bit
*.hwh
*.dcp
*.zip
hls/**/solution*/
hls/build/
hw/**/*.xpr
hw/**/*.runs/
hw/**/*.cache/
# Vivado system build + PYNQ overlay + transient build logs (regenerable: hw/tcl/ + the HLS IP + best.pt)
hw/vivado_proj/
hw/overlay/
hw/board/board_*.npz
# stratified SNR-bin eval working data (regenerable: prep_board_snr_bins.py + run_board_chunks.sh + score)
hw/board/snr_eval/
hw/board/snr_smoke/
# on-chip visual-ablation working data (regenerable: prep_board_novideo_chunks.py + run_board_chunks.sh)
hw/board/snr_eval_novideo/
hw/*.log
hw/*.out
hw/*.err
hw/*.flag

# ── Scratch / throwaway exploration ──────────────────────────────────────
scratch/
*.tmp

# ── OS / editor ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
